<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Panel - SanalHat</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../header') %>
  <div class="container" style="padding: 40px 0;">
    <h1>Admin Panel</h1>
    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 40px;">
      <div class="card" style="text-align: center;">
        <p style="color: var(--text-muted); margin: 0; font-size: 13px;">Toplam Kullanıcı</p>
        <p style="font-size: 24px; color: var(--signal); margin: 10px 0 0;"><%= stats.totalUsers %></p>
      </div>
      <div class="card" style="text-align: center;">
        <p style="color: var(--text-muted); margin: 0; font-size: 13px;">Toplam Sipariş</p>
        <p style="font-size: 24px; color: var(--signal); margin: 10px 0 0;"><%= stats.totalOrders %></p>
      </div>
      <div class="card" style="text-align: center;">
        <p style="color: var(--text-muted); margin: 0; font-size: 13px;">Aktif Siparişler</p>
        <p style="font-size: 24px; color: var(--signal); margin: 10px 0 0;"><%= stats.activeOrders %></p>
      </div>
      <div class="card" style="text-align: center;">
        <p style="color: var(--text-muted); margin: 0; font-size: 13px;">Toplam Gelir</p>
        <p style="font-size: 24px; color: var(--signal); margin: 10px 0 0;">₺<%= stats.totalRevenue %></p>
      </div>
    </div>
    <div class="card">
      <h3 style="margin-top: 0;">Hızlı Linkler</h3>
      <p><a href="/admin/kullanicilar">Kullanıcı Yönetimi</a> | <a href="/admin/servisler">Servis Fiyatları</a> | <a href="/admin/siparisler">Tüm Siparişler</a></p>
    </div>
  </div>
  <%- include('../footer') %>
</body>
</html>