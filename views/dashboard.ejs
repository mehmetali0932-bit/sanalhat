<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Panelim - SanalHat</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('header') %>
  <div class="container" style="padding: 40px 0;">
    <h1>Panel</h1>
    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>
    
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 40px;">
      <div class="card">
        <h3 style="margin-top: 0;">Bakiye</h3>
        <p style="font-size: 28px; color: var(--signal); margin: 12px 0;"><%= currentUser.balance %> kredi</p>
        <form method="POST" action="/panel/demo-bakiye-yukle">
          <div class="field-row" style="margin-bottom: 0;">
            <input type="number" name="amount" value="50" min="1" max="1000" required>
            <button type="submit" class="btn btn-primary">Yükle</button>
          </div>
        </form>
      </div>
      
      <div class="card">
        <h3 style="margin-top: 0;">API Anahtarı</h3>
        <p style="font-family: var(--font-mono); font-size: 12px; word-break: break-all; margin-bottom: 12px;"><%= currentUser.apiKey %></p>
        <form method="POST" action="/panel/api-anahtari-yenile" style="display: inline;">
          <button type="submit" class="btn btn-ghost btn-sm">Yenile</button>
        </form>
      </div>
    </div>

    <h2>Numara Satın Al</h2>
    <div class="card">
      <form method="POST" action="/panel/satin-al">
        <div class="field-row">
          <div class="field">
            <label>Servis</label>
            <select name="serviceId" required>
              <% services.forEach(s => { %>
                <option value="<%= s.id %>"><%= s.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="field">
            <label>Ülke</label>
            <select name="countryId" required>
              <% countries.forEach(c => { %>
                <option value="<%= c.id %>"><%= c.name %></option>
              <% }) %>
            </select>
          </div>
        </div>
        <button type="submit" class="btn btn-primary btn-block">Satın Al</button>
      </form>
    </div>

    <h2 style="margin-top: 40px;">Siparişlerim</h2>
    <% if (orders.length === 0) { %>
      <p style="color: var(--text-muted);">Henüz siparişin yok.</p>
    <% } else { %>
      <% orders.forEach(o => { %>
        <div class="card" id="siparis-<%= o.id %>">
          <div style="display: flex; justify-content: space-between; align-items: center;">
            <div>
              <h4 style="margin: 0;"><%= o.serviceName %> - <%= o.countryName %></h4>
              <p style="margin: 4px 0; color: var(--text-muted); font-size: 13px;">Sipariş: <%= o.id %></p>
              <p style="margin: 4px 0; font-family: var(--font-mono); font-size: 14px;"><%= o.phoneNumber %></p>
              <% if (o.smsCode) { %>
                <p style="margin: 4px 0; color: var(--signal); font-family: var(--font-mono); font-size: 16px; font-weight: bold;"><%= o.smsCode %></p>
              <% } %>
            </div>
            <div style="text-align: right;">
              <span class="badge badge-<%= o.status.toLowerCase() %>"><%= o.status %></span>
              <% if (o.status === 'PENDING') { %>
                <form method="POST" action="/panel/siparis/<%= o.id %>/iptal" style="display: inline; margin-top: 8px;">
                  <button type="submit" class="btn btn-danger btn-sm">İptal</button>
                </form>
              <% } else if (o.status === 'RECEIVED') { %>
                <form method="POST" action="/panel/siparis/<%= o.id %>/tamamla" style="display: inline; margin-top: 8px;">
                  <button type="submit" class="btn btn-primary btn-sm">Tamamla</button>
                </form>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>
  <%- include('footer') %>
</body>
</html>