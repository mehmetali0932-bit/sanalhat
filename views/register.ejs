<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Kayıt Ol - SanalHat</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('header') %>
  <div class="auth-wrap">
    <div class="card">
      <h2 style="text-align: center; margin-top: 0;">Kayıt Ol</h2>
      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>
      <form method="POST" action="/kayit">
        <div class="field">
          <label>E-posta</label>
          <input type="email" name="email" required>
        </div>
        <div class="field">
          <label>Şifre</label>
          <input type="password" name="password" required>
        </div>
        <div class="field">
          <label>Şifre Tekrar</label>
          <input type="password" name="passwordConfirm" required>
        </div>
        <button type="submit" class="btn btn-primary btn-block" style="margin-top: 16px;">Kayıt Ol</button>
      </form>
      <p class="muted-link" style="text-align: center; margin-top: 16px;">
        Zaten hesabın var? <a href="/giris">Giriş Yap</a>
      </p>
    </div>
  </div>
  <%- include('footer') %>
</body>
</html>